    "usercss": "/* ============================================================\n   4chan X — Focused Reading CSS  v3\n   Base theme: Tomorrow  (set in 4chan X Settings)\n   Install: 4chan X → Settings → General → Custom CSS\n   ============================================================ */\n\n\n/* ── PALETTE ─────────────────────────────────────────────────\n   Anchored to your chosen page bg: #26272c\n   Each layer steps ~8-10 lightness points above the last.\n\n   #26272c  → page background      (your pick)\n   #2e3035  → reply blocks          (+8 lightness)\n   #383c42  → OP / hover / borders  (+10 more)\n   #444950  → active borders        (+8 more)\n\n   Text and accents are tuned for contrast on #26272c.\n   ---------------------------------------------------------- */\n:root.tomorrow {\n  /* Backgrounds — layered from your base outward */\n  --fc-bg:         #26272c;   /* page / outer — YOUR COLOR */\n  --fc-bg2:        #2e3035;   /* reply blocks */\n  --fc-bg3:        #383c42;   /* OP block / hover rows */\n  --fc-border:     #444950;   /* post borders — visible but soft */\n\n  /* Text */\n  --fc-text:       #d4d7d3;   /* main body — warm near-white */\n  --fc-text-dim:   #636b74;   /* timestamps, post#, file info */\n\n  /* Accents — all tuned for contrast on the new base */\n  --fc-green:      #6db568;   /* greentext — warm sage */\n  --fc-link:       #82b2d8;   /* links — soft sky blue */\n  --fc-link-you:   #e29a60;   /* (You) — warm amber */\n  --fc-subject:    #caca6e;   /* subject — warm yellow-green */\n  --fc-spoiler-bg: #26272c;\n  --fc-highlight:  rgba(226,154,96,0.08);\n}\n\n/* Daylight nudge — slightly brighter backgrounds when\n   the OS reports light mode, same accent colors */\n@media (prefers-color-scheme: light) {\n  :root.tomorrow {\n    --fc-bg:      #2c2e34;\n    --fc-bg2:     #353840;\n    --fc-bg3:     #40454d;\n    --fc-border:  #4e545d;\n    --fc-text:    #dfe2de;\n    --fc-text-dim:#7e8690;\n  }\n}\n\n\n/* ── BODY ────────────────────────────────────────────────── */\n:root.tomorrow body {\n  font-family: Inter, system-ui, -apple-system, Helvetica, sans-serif;\n  font-size: 17px;           /* was 15px → +2px */\n  line-height: 1.7;\n  color: var(--fc-text);\n  background-color: var(--fc-bg);\n}\n\n\n/* ── BOARD TITLE ─────────────────────────────────────────── */\n:root.tomorrow div.boardTitle {\n  font-family: Inter, sans-serif !important;\n  font-weight: 400 !important;\n  text-shadow: 1px 1px 2px rgba(10,10,12,0.6);\n}\n\n\n/* ── THREAD SUBJECT ──────────────────────────────────────── */\n:root.tomorrow div.post div.postInfo span.subject {\n  font-weight: 600;\n  font-size: 18px;           /* was 16px → +2px */\n  color: var(--fc-subject) !important;\n  letter-spacing: 0.01em;\n}\n\n\n/* ── HIDE NAME BLOCK — collapse its space fully ──────────────\n   Zero out all box dimensions so no phantom gap remains,\n   then strip postInfo's indent that existed for the name,\n   and align postMessage flush with a small breathing margin.\n   ---------------------------------------------------------- */\ndiv.post div.postInfo span.nameBlock {\n  display: none !important;\n  margin: 0 !important;\n  padding: 0 !important;\n  width: 0 !important;\n}\n\n:root.tomorrow div.post div.postInfo {\n  padding-left: 0 !important;\n  margin-left: 0 !important;\n  display: flex;\n  align-items: baseline;\n  gap: 6px;\n  flex-wrap: wrap;\n}\n\n:root.tomorrow div.post div.postMessage,\n:root.tomorrow .postMessage {\n  margin-left: 4px !important;\n  margin-top: 5px !important;\n}\n\ndiv.reply input { display: none; }\n\n\n/* ── POST META — de-emphasised ───────────────────────────── */\n:root.tomorrow div.post div.postInfo,\n:root.tomorrow .postNum,\n:root.tomorrow .dateTime,\n:root.tomorrow span.postNum a,\n:root.tomorrow .postNum a[title] {\n  color: var(--fc-text-dim) !important;\n  font-size: 13px !important;   /* was 12px → +1px (meta stays smaller) */\n}\n\n\n/* ── GREENTEXT ───────────────────────────────────────────── */\n:root.tomorrow .postMessage .quote,\n:root.tomorrow .quote {\n  color: var(--fc-green) !important;\n  font-style: italic;\n}\n\n\n/* ── FILE INFO ───────────────────────────────────────────── */\n:root.tomorrow .fileText,\n:root.tomorrow .file-info,\n:root.tomorrow div.file .fileInfo,\n:root.tomorrow .postFile,\n:root.tomorrow .file > div {\n  font-size: 12px !important;   /* was 11px → +1px */\n  opacity: 0.45;\n  transition: opacity 0.2s ease;\n  margin-left: 4px !important;\n}\n:root.tomorrow .fileText:hover,\n:root.tomorrow .file-info:hover,\n:root.tomorrow div.file .fileInfo:hover,\n:root.tomorrow .postFile:hover,\n:root.tomorrow .file > div:hover {\n  opacity: 0.82;\n}\n\n\n/* ── (YOU) HIGHLIGHT ─────────────────────────────────────── */\n:root.tomorrow .post.highlight,\n:root.tomorrow .replyContainer.highlight {\n  background-color: var(--fc-highlight) !important;\n  border-left: 2px solid var(--fc-link-you) !important;\n  padding-left: 2px !important;\n}\n:root.tomorrow span.youmark,\n:root.tomorrow .backlink.you > a {\n  color: var(--fc-link-you) !important;\n  font-weight: 600;\n}\n\n\n/* ── LINKS ───────────────────────────────────────────────── */\n:root.tomorrow a.quotelink,\n:root.tomorrow .postMessage a {\n  color: var(--fc-link) !important;\n  text-decoration: none;\n}\n:root.tomorrow a.quotelink:hover,\n:root.tomorrow .postMessage a:hover {\n  text-decoration: underline;\n  opacity: 0.85;\n}\n:root.tomorrow a         { color: var(--fc-link); }\n:root.tomorrow a:visited { color: #6a8fae; }\n\n\n/* ── REPLY BLOCKS ────────────────────────────────────────── */\n:root.tomorrow .reply {\n  background-color: var(--fc-bg2) !important;\n  border-color: var(--fc-border) !important;\n}\n\n\n/* ── CATALOG ─────────────────────────────────────────────── */\n:root.tomorrow .catalog-stats {\n  font-size: 13px;           /* was 12px → +1px */\n  font-weight: 600;\n  color: var(--fc-text-dim);\n}\n:root.tomorrow .catalog-post > .postMessage {\n  margin: 0 !important;\n  padding-bottom: 0.3em;\n  font-size: 15px;           /* was 13px → +2px */\n  line-height: 1.55;\n}\n\n\n/* ── HIDE STUBS & BUTTONS ────────────────────────────────── */\ndiv.stub { display: none; }\n.hide-thread-button:not(:hover),\n.hide-reply-button:not(:hover) { display: none; }\n\n\n/* ── 4chan X QR / PANEL ──────────────────────────────────── */\n:root {\n  --xt-fxt-bg:     #26272c;\n  --xt-fxt-border: #444950;\n}\n\n\n/* ── UNREAD LINE ─────────────────────────────────────────── */\n:root.tomorrow #unread-line {\n  border-color: var(--fc-link-you) !important;\n  opacity: 0.55;\n}\n\n\n/* ── SLIM SCROLLBAR ──────────────────────────────────────── */\n:root.tomorrow ::-webkit-scrollbar        { width: 5px; height: 5px; }\n:root.tomorrow ::-webkit-scrollbar-track  { background: var(--fc-bg); }\n:root.tomorrow ::-webkit-scrollbar-thumb  { background: var(--fc-bg3); border-radius: 3px; }\n:root.tomorrow ::-webkit-scrollbar-thumb:hover { background: var(--fc-text-dim); }\n\n\n/* ============================================================\n   OTHER THEMES — fallback / compatibility\n   ============================================================ */\n\n.quote { font-style: italic; }\n\n/* Yotsuba B */\n:root.yotsuba-b body { font-family: Inter, Helvetica, sans-serif; font-size: 17px; line-height: 1.7; color: #000; }\n:root.yotsuba-b div.boardTitle { font-family: sans-serif !important; font-weight: 400 !important; text-shadow: 1px 1px 1px rgba(105,10,15,0.6); }\n:root.yotsuba-b div.post div.postInfo span.subject { color: #000; font-weight: 600; font-size: 18px; }\n:root.yotsuba-b .catalog-stats { font-size: 13px; font-weight: 700; }\n:root.yotsuba-b .catalog-post > .postMessage { margin: 0; padding-bottom: 0.3em; font-size: 15px; }\n\n/* Yotsuba */\n:root.yotsuba body { font-family: Inter, Helvetica, sans-serif; font-size: 17px; line-height: 1.7; }\n:root.yotsuba div.boardTitle { font-family: sans-serif !important; font-weight: 400 !important; text-shadow: 1px 1px 1px rgba(100,0,0,0.6); }\n:root.yotsuba div.post div.postInfo span.subject { font-weight: 600; font-size: 18px; }\n:root.yotsuba .catalog-stats { font-size: 13px; font-weight: 700; }\n:root.yotsuba .catalog-post > .postMessage { margin: 0; padding-bottom: 0.3em; font-size: 15px; }\n\n/* Photon */\n:root.photon div.boardTitle { font-family: sans-serif !important; font-weight: 400 !important; text-shadow: 1px 1px 1px rgba(0,74,153,0.6); }",
